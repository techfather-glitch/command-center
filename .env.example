# Command Center configuration — copy to `.env`. Every variable is optional.

# Port the server listens on.
PORT=8888

# Timezone for timestamps (e.g. America/New_York, Europe/London).
TZ=UTC

# Set to 1 to serve a fully synthetic demo homelab (no real config needed).
DEMO=

# Require a sign-in session on every API call. Leave blank on a trusted LAN.
# Use DASHBOARD_PASSWORD_FILE instead to load from a Docker/K8s secret.
DASHBOARD_PASSWORD=

# When behind a reverse proxy, pin the external origin so links & cookies are
# correct, e.g. https://cc.example.com
PUBLIC_URL=

# Honor X-Forwarded-* headers (1 = yes, default). Set 0 for a direct, untrusted
# bind where forwarded headers should not be trusted.
TRUST_PROXY=1

# Where writable state (settings, encrypted vault, audit log) is stored inside
# the container. The compose file mounts ./data here.
DATA_DIR=/app/data
